[Unit]
Description=OSC Video Player (Wayland Kiosk)
After=systemd-user-sessions.service plymouth-quit-wait.service
Conflicts=getty@tty1.service

[Service]
User=tomi
PAMName=login
WorkingDirectory=/home/tomi/own-osc-player

# Safeguard, in case the system fails to create the directory in time
ExecStartPre=+/bin/mkdir -p /run/user/1000
ExecStartPre=+/bin/chown tomi:tomi /run/user/1000

Environment="XDG_RUNTIME_DIR=/run/user/1000"

# WE ARE ADDING THIS:
# 1. Ignores missing mouse and keyboard
Environment="WLR_LIBINPUT_NO_DEVICES=1"
# 2. Forces reliable OpenGL ES rendering
Environment="WLR_RENDERER=gles2"

# Přidán parametr '-d' pro plný debug log kompozitoru Cage
ExecStart=/bin/bash -c '/usr/bin/cage -d -s -- env SDL_VIDEO_DRIVER=wayland SDL_LOG_ALL=debug /home/tomi/own-osc-player/own-osc-player > /home/tomi/own-osc-player/cage_debug.log 2>&1'

StandardInput=tty
StandardOutput=journal
StandardError=journal
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target